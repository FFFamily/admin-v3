# In production we usually rely on the web server (Nginx) to proxy `/api` to backend,
# so keep browser requests same-origin.
VITE_BASE_API=/api

# Optional: used to build absolute file URLs stored to backend.
# Keep it aligned with the legacy Vue2 `VUE_APP_BASE_URL`.
VITE_API_BASE_URL=https://www.funingeco.com/api
