# Base path used by axios in the browser.
VITE_BASE_API=/api

# Backend origin used by Vite dev-server proxy (avoids browser CORS).
# Equivalent to Vue2's `VUE_APP_BASE_URL` in vue.config.js.
VITE_PROXY_TARGET=http://127.0.0.1:8090

# Optional: used to build absolute file URLs stored to backend.
# In Vue2 this was `VUE_APP_BASE_URL`.
VITE_API_BASE_URL=http://127.0.0.1:8090

# Optional: override Vite port if needed
# VITE_PORT=5173
